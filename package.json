{
  "name": "eot-firebase-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "check:deploy": "node scripts/check-deploy.mjs",
    "build": "tsc -b && vite build",
    "build:book-packs": "node scripts/build-book-packs.mjs",
    "build:shell": "npm run check:deploy && npm run build && npm run build:book-packs",
    "deploy:shell": "npm run build:shell && firebase deploy --only hosting:empireot",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "dexie": "^4.4.4",
    "firebase": "^12.1.0",
    "idb": "^8.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.8.0",
    "vite": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.0"
  }
}
